# ── PostgreSQL ─────────────────────────────────────────────────
# Async URL for SQLAlchemy (runtime)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/graphrag_db
# Sync URL for Alembic (migrations only)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/graphrag_db

# ── JWT Auth ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_this_to_a_strong_random_secret_key_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_PREFIX=graphrag

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Gemini ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# ── App ───────────────────────────────────────────────────────
APP_ENV=development         # development | production
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
